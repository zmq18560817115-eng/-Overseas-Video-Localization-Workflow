# =============================================================================
# 海外短视频本地化 MVP · 环境配置
# =============================================================================
# 核心 AIGC：SeedDance 2.0（fal.ai）— 用于 Step 6 生成 AI 空镜视频
# 英文脚本：规则模板 + 人工粘贴，不依赖 Claude 等外部文案大模型
# =============================================================================

# --- SeedDance 2.0（二选一）---
# 推荐：火山方舟 Ark（官方 SeedDance 2.0 API）
SEEDANCE_PROVIDER=ark
ARK_API_KEY=
ARK_SEEDANCE_TEXT_MODEL=doubao-seedance-2-0-260128
ARK_SEEDANCE_FAST_MODEL=doubao-seedance-2-0-fast-260128

# 备选：fal.ai
FAL_KEY=
# 设为 1 使用 fast 模型（更快，适合试跑）
SEEDANCE_USE_FAST=0

DECOMPOSE_PROVIDER=auto
DOUBAO_VIDEO_ANALYSIS_MODEL=doubao-seed-2-1-turbo-260628
DOUBAO_VIDEO_ANALYSIS_MODEL_PRO=doubao-seed-2-1-pro-260628
DOUBAO_VIDEO_ANALYSIS_MODE=auto
DOUBAO_ASR_ENABLED=1

# broll = 仅痛点镜空镜；script = 按脚本 5 镜各生成约 5 秒短视频
AI_VIDEO_MODE=script
# 完成交付时自动生成（1=开，0=关）
AI_VIDEO_ON_FINISH=1
# 每次最多生成几镜（0=全部；试跑可设 2）
AI_VIDEO_MAX_SHOTS=2

# fal.ai 模型（仅 SEEDANCE_PROVIDER=fal 时）
SEEDANCE_IMAGE_MODEL=bytedance/seedance-2.0/image-to-video
SEEDANCE_TEXT_MODEL=bytedance/seedance-2.0/text-to-video

# --- 英文脚本 Prompt 版本（规则模板用）---
OVERSEAS_LOC_PROMPT_VERSION=localize-v1.1

# --- 知识库 ---
KNOWLEDGE_RESEARCH_ROOT=
KRO_CONFIG_PATH=../config/knowledge-sources.json
KRO_SCRIPT_PATH=

# --- 本地服务 ---
OVERSEAS_LOC_HOST=127.0.0.1
OVERSEAS_LOC_PORT=8787

# --- 说明 ---
# 未填 ARK_API_KEY / FAL_KEY：Step 6 仍可「仅保存请求预览」
# Step 4 英文脚本：页面点「按规则模板生成」或「保存人工粘贴文案」
