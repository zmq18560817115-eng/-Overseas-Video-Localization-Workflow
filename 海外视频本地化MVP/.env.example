# Knowledge Research Orchestrator（KRO）
KNOWLEDGE_RESEARCH_ROOT=\\DS223\obsidian知识库
KRO_CONFIG_PATH=../config/knowledge-sources.json
# KRO_SCRIPT_PATH=   # 可选；默认 ~/.codex/skills/... 或 Downloads 下的 KRO

# 脚本生成（可选）：Windows 用户环境变量 ANTHROPIC_API_KEY，或在此填写
# ANTHROPIC_API_KEY=
# OVERSEAS_LOC_MODEL=claude-sonnet-4-6

# SeedDance 2.0（fal.ai）密钥写在同级目录 overseas-loc-mvp/.env
# 也可运行工作区根目录「配置SeedDance.cmd」
# FAL_KEY=

# 视频结构拆解暂停（写在 overseas-loc-mvp/.env，与 ARK_API_KEY 同文件）
# DOUBAO_VIDEO_ANALYSIS_ENABLED=0  # 不调用豆包大模型（含手动重试、批量拆解）
# VIDEO_ANALYSIS_AUTO=0            # 新抓取素材不自动/批量分析；已有结果永不重复分析
# OVERSEAS_DB_USERNAME=
# OVERSEAS_DB_PASSWORD=
